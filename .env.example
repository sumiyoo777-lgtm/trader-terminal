# ---------------------------------------------------------------
# Trader Terminal environment. Copy to backend/.env and fill in.
# Never commit a real .env. Never hardcode keys in code.
# ---------------------------------------------------------------

# SQLAlchemy URL. Defaults to a local SQLite file (zero setup).
# For PostgreSQL: postgresql+psycopg2://user:pass@localhost:5432/trader_terminal
DATABASE_URL=sqlite:///./terminal.db

# Only needed if you later move jobs to a Redis-backed queue. Unused by the
# default APScheduler in-process scheduler.
REDIS_URL=

# FlashAlpha Lab (https://lab.flashalpha.com) key for real dealer GEX.
FLASHALPHA_API_KEY=

# Optional NewsAPI.org key. If empty, the free yfinance news provider is used.
NEWS_API_KEY=

# Optional paid market-data key (not required: yfinance is the default source).
MARKET_DATA_API_KEY=

# Local Kronos model (Mode B). Leave defaults if you provisioned the
# ~/.claude/skills/kronos venv; the runner finds it automatically.
KRONOS_MODEL_PATH=
KRONOS_DEVICE=cpu

DEFAULT_SYMBOL=MES
# yfinance ticker used to observe MES prices
MARKET_DATA_TICKER=MES=F

GEX_PRIMARY_SYMBOL=SPX
GEX_SECONDARY_SYMBOL=SPY
# When FlashAlpha can't serve data (free-tier key, quota, outage), fall back
# to a clearly-labeled self-computed GEX (BS gamma x OI from the option chain)
ENABLE_SELF_COMPUTED_GEX=true
# Comma-separated NY-session GEX snapshot times (America/New_York)
GEX_SCHEDULE=09:35,10:30,11:30,13:30,15:30

APP_TIMEZONE=America/New_York

ENABLE_LOCAL_KRONOS=false
ENABLE_NEWS_SCORING=true
ENABLE_GEX_JOBS=true
ENABLE_COT_JOBS=true
# Master switch for the in-process APScheduler (jobs run inside the API process)
ENABLE_SCHEDULER=true

# News job cadence in minutes during market hours (5-15 recommended)
NEWS_REFRESH_MINUTES=10

# Kalman slider default (0 = trust Kronos, 100 = trust live price)
KALMAN_SLIDER_DEFAULT=50

# Demo seed mode: "true" loads clearly-labeled synthetic demo data on first
# boot so the UI is reviewable without API keys. Demo rows are tagged
# source/metadata "DEMO" and never mix silently with real data.
DEMO_SEED=false
